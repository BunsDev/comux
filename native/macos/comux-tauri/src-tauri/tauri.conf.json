{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "comux",
  "version": "0.0.7",
  "identifier": "dev.buns.comux.tauri",
  "build": {
    "beforeDevCommand": "python3 -m http.server 1420 --bind 127.0.0.1 --directory web",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "comux",
        "width": 1280,
        "height": 800,
        "minWidth": 980,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https: http:; style-src 'self'; script-src 'self'; frame-src https: http:; connect-src 'self' ipc: http://ipc.localhost https: http:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  },
  "plugins": {
    "opener": {}
  }
}
